#!/bin/bash
# get-new-dotfiles — find untracked files under stowed target dirs and claim them
#
# When opencode (or anything else) creates files directly under a Stow-managed
# target directory (e.g. ~/.config/opencode/skills/foo/SKILL.md), those files
# live outside the repo. This script moves them into the repo and restows.
#
# Usage:
#   get-new-dotfiles            # move + restow
#   get-new-dotfiles --dry-run  # preview only
set -euo pipefail

REPO="$(cd "$(dirname "$0")/.." && pwd)"
dry_run=false

for arg in "$@"; do
  case "$arg" in
    --dry-run|-n) dry_run=true ;;
  esac
done

# Packages whose Stow target under $HOME is a directory (not a single file).
# When adding a new package with a directory target, add it here.
PACKAGES=(opencode claude btop lla)
TARGETS=(".config/opencode" ".claude" ".config/btop" ".config/lla")

any_found=false
declare -a affected=()

for i in "${!PACKAGES[@]}"; do
  pkg="${PACKAGES[$i]}"
  rel="${TARGETS[$i]}"
  target="$HOME/$rel"
  pkg_path="$REPO/$pkg/$rel"

  [ ! -d "$target" ] && continue

  # Collect candidate real files not yet tracked in the repo
  declare -a candidates=()
  while IFS= read -r -d '' file; do
    file_rel="${file#$target/}"
    repo_file="$pkg_path/$file_rel"
    if [ ! -f "$repo_file" ] && [ ! -L "$repo_file" ]; then
      candidates+=("$file_rel")
    fi
  done < <(find "$target" -type f ! -type l \
    -not -path "*/.git/*"     \
    -not -path "*/node_modules/*" \
    -not -name "package.json"     \
    -not -name "package-lock.json" \
    -not -name "bun.lock"         \
    -not -name ".gitignore"       \
    -print0 2>/dev/null)

  [ ${#candidates[@]} -eq 0 ] && continue

  any_found=true
  affected+=("$pkg")

  if $dry_run; then
    # Group by first two path components (directory root)
    echo "$pkg/:"
    printf '%s\n' "${candidates[@]}" \
      | cut -d/ -f1-2 \
      | sort \
      | uniq -c \
      | sort -rn \
      | while read -r count dir; do
          printf "  %s/  (%d files)\n" "$dir" "$count"
        done
  else
    for file_rel in "${candidates[@]}"; do
      repo_file="$pkg_path/$file_rel"
      mkdir -p "$(dirname "$repo_file")"
      mv "$target/$file_rel" "$repo_file"
    done
    echo "Claimed ${#candidates[@]} files in $pkg/"
  fi
done

if ! $any_found; then
  echo "No untracked files found under stowed target directories."
  exit 0
fi

if $dry_run; then
  echo
  echo "Run without --dry-run to claim them."
  exit 0
fi

# Restow packages that had files claimed
for pkg in "${affected[@]}"; do
  echo "Restowing $pkg..."
  stow -R -t "$HOME" -d "$REPO" "$pkg"
done

echo "Done. New files are now tracked and symlinked."
